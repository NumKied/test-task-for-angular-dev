{
  "name": "block-builder",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/block-builder/src",
  "prefix": "lib",
  "projectType": "library",
  "tags": ["ui"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/block-builder",
        "main": "libs/block-builder/src/index.ts",
        "tsConfig": "libs/block-builder/tsconfig.lib.json",
        "assets": ["libs/block-builder/*.md"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/block-builder/jest.config.cts",
        "tsConfig": "libs/block-builder/tsconfig.spec.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
