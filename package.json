{
  "name": "ng-x-rocket",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "build": "npm run write:env -s && nx build --configuration production",
    "start": "npm run write:env -s && nx serve --proxy-config proxy.conf.js",
    "serve:sw": "npm run build -s && npx http-server ./dist -p 4200",
    "lint": "nx lint && stylelint \"src/**/*.scss\" --syntax scss && htmlhint \"src\" --config .htmlhintrc",
    "test": "npm run write:env -s && nx test",
    "test:ci": "npm run write:env -s && npm run lint -s && nx test --configuration=ci",
    "e2e": "npm run write:env -s && nx e2e",
    "translations:extract": "ngx-translate-extract --input ./src --output ./src/translations/template.json --format=json --clean --sort",
    "docs": "hads ./docs -o",
    "write:env": "ngx-scripts env npm_package_version",
    "generate": "nx generate"
  },
  "dependencies": {
    "@angular-devkit/build-angular": "^20.3.18",
    "@angular/animations": "^20.3.18",
    "@angular/cdk": "~20.2.14",
    "@angular/common": "^20.3.18",
    "@angular/compiler": "^20.3.18",
    "@angular/core": "^20.3.18",
    "@angular/forms": "^20.3.18",
    "@angular/localize": "^20.3.18",
    "@angular/material": "~20.2.14",
    "@angular/platform-browser": "^20.3.18",
    "@angular/platform-browser-dynamic": "^20.3.18",
    "@angular/router": "^20.3.18",
    "@angular/service-worker": "^20.3.18",
    "@fortawesome/fontawesome-free": "^5.15.1",
    "@larrym/ngx-translate-extract-marker": "^1.0.0",
    "@ng-bootstrap/ng-bootstrap": "^19.0.1",
    "@ngx-translate/core": "^14.0.0",
    "@ngx-translate/http-loader": "^7.0.0",
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^4.5.3",
    "ngx-translate-extract": "^1.0.0",
    "rxjs": "^6.6.3",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/core": "^20.3.18",
    "@angular-devkit/schematics": "^20.3.18",
    "@angular/cdk": "^20.2.14",
    "@angular/cli": "^20.3.21",
    "@angular/compiler-cli": "^20.3.18",
    "@angular/language-service": "^20.3.18",
    "@angular/material": "^20.2.14",
    "@eslint/js": "^9.8.0",
    "@ngneat/until-destroy": "^8.0.3",
    "@ngx-rocket/scripts": "^5.0.0",
    "@nx/angular": "^22.6.1",
    "@nx/eslint": "22.6.1",
    "@nx/eslint-plugin": "22.6.1",
    "@nx/jest": "22.6.1",
    "@nx/js": "22.6.1",
    "@nx/workspace": "22.6.1",
    "@schematics/angular": "^20.3.21",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/jasmine": "^3.6.2",
    "@types/jasminewd2": "^2.0.8",
    "@types/jest": "^30.0.0",
    "@types/node": "^12.19.12",
    "@typescript-eslint/utils": "^8.40.0",
    "angular-eslint": "^20.3.0",
    "autoprefixer": "^10.4.0",
    "codelyzer": "^6.0.1",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "hads": "^3.0.0",
    "htmlhint": "^0.14.2",
    "https-proxy-agent": "^5.0.0",
    "husky": "^4.3.6",
    "jasmine-core": "~3.6.0",
    "jasmine-spec-reporter": "~6.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.0.2",
    "jest-preset-angular": "^16.1.1",
    "jest-util": "^30.0.2",
    "jsonc-eslint-parser": "^2.1.0",
    "ng-packagr": "~20.3.0",
    "nx": "22.6.1",
    "postcss": "^8.4.5",
    "postcss-url": "~10.1.3",
    "prettier": "~3.6.2",
    "pretty-quick": "^4.2.2",
    "protractor": "~7.0.0",
    "stylelint": "~13.8.0",
    "stylelint-config-prettier": "^8.0.2",
    "stylelint-config-recommended-scss": "~4.2.0",
    "stylelint-config-standard": "~20.0.0",
    "stylelint-scss": "~3.18.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^9.1.1",
    "tslint": "~6.1.0",
    "tslint-config-prettier": "^1.18.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.40.0"
  },
  "prettier": {
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.scss",
        "options": {
          "singleQuote": false
        }
      }
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "pretty-quick --staged"
    }
  },
  "nx": {}
}
