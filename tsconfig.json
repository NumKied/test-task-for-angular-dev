{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "outDir": "./dist/out-tsc",
    "sourceMap": false,
    "module": "commonjs"
  },
  "include": [
    "**/*.ts",
    "**/*.js",
    "src/**/*.spec.ts",
    "src/**/*.spec.js",
    "src/**/*.test.ts",
    "src/**/*.test.js",
    "src/**/*.d.ts",
    "apps/ng-x-rocket/jest.config.ts",
    "apps/ng-x-rocket-e2e/playwright.config.ts"
  ]
}
