{
  "compileOnSave": false,
  "compilerOptions": {
    "outDir": "./dist/out-tsc",
    "sourceMap": true,
    "declaration": false,
    "esModuleInterop": true,
    "module": "es2020",
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "noImplicitAny": true,
    "target": "ES2022",
    "typeRoots": ["node_modules/@types"],
    "lib": ["es2018", "dom"],
    "baseUrl": ".",
    "paths": {
      "weather-ui": ["libs/weather/ui/weather-ui/src/index.ts"],
      "weather-state": ["libs/weather/state/weather-state/src/index.ts"],
      "helpers": ["libs/shared/helpers/src/index.ts"],
      "block-builder": ["libs/block-builder/src/index.ts"]
    },
    "useDefineForClassFields": false,
    "rootDir": "."
  },
  "angularCompilerOptions": {
    "strictInjectionParameters": true,
    "preserveWhitespaces": true
  },
  "exclude": ["node_modules", "tmp"]
}
